<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Browser Toolbar -->
        <LinearLayout
            android:id="@+id/toolbar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:background="@color/toolbar_background"
            android:elevation="2dp">

            <!-- Tab counter / Incognito indicator -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_counter"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/tabs_count"
                android:textSize="11sp"
                android:textColor="@color/md_theme_primary"
                app:icon="@drawable/ic_tabs"
                app:iconSize="18dp"
                app:iconTint="@color/md_theme_primary"
                app:iconPadding="0dp" />

            <!-- URL/Omnibox Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/url_bar_container"
                style="@style/UrlBarStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <!-- Security indicator -->
                    <ImageView
                        android:id="@+id/iv_security"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_lock"
                        android:contentDescription="Security"
                        android:visibility="gone" />

                    <!-- URL text -->
                    <EditText
                        android:id="@+id/et_url"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/search_hint"
                        android:inputType="textUri"
                        android:imeOptions="actionGo|flagNoExtractUi"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="@color/md_theme_on_surface"
                        android:textColorHint="@color/md_theme_outline"
                        android:textSize="14sp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:importantForAutofill="no" />

                    <!-- Clear URL button -->
                    <ImageButton
                        android:id="@+id/btn_clear_url"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Clear"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_menu"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_more"
                app:iconSize="22dp"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Find in Page bar -->
        <LinearLayout
            android:id="@+id/find_in_page_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@color/md_theme_surface_container"
            android:visibility="gone"
            android:elevation="1dp">

            <EditText
                android:id="@+id/et_find"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Find in page"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:singleLine="true"
                android:textSize="14sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/tv_find_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/md_theme_outline"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_find_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_media_prev"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Previous" />

            <ImageButton
                android:id="@+id/btn_find_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_media_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Next" />

            <ImageButton
                android:id="@+id/btn_find_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:progressTint="@color/md_theme_primary" />

        <!-- Tab content container -->
        <FrameLayout
            android:id="@+id/tab_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Snackbar / Toast area -->
        <LinearLayout
            android:id="@+id/snackbar_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Bottom Navigation Bar (no FAB) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/toolbar_background"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconSize="20dp"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_forward"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconSize="20dp"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_home"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_home"
            app:iconSize="20dp"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_bookmark"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_bookmark_add"
            app:iconSize="20dp"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_devtools"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_info"
            app:iconSize="20dp"
            app:iconPadding="0dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
