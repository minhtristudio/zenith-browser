<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zenith"
            android:textSize="36sp"
            android:textColor="@color/md_theme_primary"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fast. Secure. Extensible."
            android:textSize="14sp"
            android:textColor="@color/md_theme_outline"
            android:layout_marginBottom="40dp" />

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/search_card"
            style="@style/UrlBarStyle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="32dp"
            app:strokeColor="@color/md_theme_outline_variant"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Search with Google or enter URL"
                android:inputType="textUri"
                android:imeOptions="actionSearch|flagNoExtractUi"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/md_theme_on_surface"
                android:textColorHint="@color/md_theme_outline"
                android:textSize="16sp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:importantForAutofill="no" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Links -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shortcuts"
            android:textSize="14sp"
            android:textColor="@color/md_theme_on_surface_variant"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_shortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp" />

        <!-- Recent Bookmarks -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recent Bookmarks"
            android:textSize="14sp"
            android:textColor="@color/md_theme_on_surface_variant"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>
